{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "dashboard",
      "runtimeExecutable": "node",
      "runtimeArgs": ["-e", "const h=require('http'),f=require('fs'),p=require('path');h.createServer((q,r)=>{let u=q.url.split('?')[0];if(u==='/')u='/index.html';const fp=p.join(process.cwd(),'dashboard',u);const ext=p.extname(fp);const ct={'html':'text/html','js':'text/javascript','css':'text/css','json':'application/json','svg':'image/svg+xml'}[ext.slice(1)]||'application/octet-stream';f.readFile(fp,(e,d)=>{if(e){r.writeHead(404);r.end('Not found');return}r.writeHead(200,{'Content-Type':ct});r.end(d)})}).listen(8765,()=>console.log('Serving on 8765'))"],
      "port": 8765
    }
  ]
}
